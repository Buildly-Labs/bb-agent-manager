# Buildly MCP Server — Environment Configuration
# Copy to .env and fill in your values.
#
# NOTE: Model/LLM provider settings do NOT belong here.
# Model selection is handled by the external MCP client:
#   - GitHub Copilot selects the model
#   - Copilot CLI + Ollama runs models locally
#   - Claude Desktop selects Claude

# ---------------------------------------------------------------------------
# Buildly Labs (required for Labs integration tools)
# ---------------------------------------------------------------------------
LABS_BASE_URL=https://labs-api.buildly.io

# API token — get this from Buildly Labs or run buildly_login tool
# If not set, use the buildly_login tool to authenticate interactively.
LABS_API_TOKEN=

# ---------------------------------------------------------------------------
# Buildly project context (recommended)
# ---------------------------------------------------------------------------

# Label for the current environment (used in context tools)
BUILDLY_ENV_NAME=local

# UUID of the product you're working on — scopes issue/feature tools
BUILDLY_PRODUCT_UUID=

# UUID of your organization
BUILDLY_ORG_UUID=

# ---------------------------------------------------------------------------
# GitHub integration (optional — for PR tools)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ---------------------------------------------------------------------------
# Local paths (optional — defaults shown)
# ---------------------------------------------------------------------------
DEVDOCS_PATH=devdocs
MEMORY_PATH=buildly_memory

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
DEBUG=0

